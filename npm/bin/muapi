#!/usr/bin/env node
/**
 * muapi CLI shim — finds and executes the platform-specific binary.
 */
const path = require("path");
const fs   = require("fs");
const { spawnSync } = require("child_process");

const plat = process.platform;  // darwin | linux | win32
const arch = process.arch;       // arm64 | x64

const NAME_MAP = {
  "darwin-arm64": "muapi-darwin-arm64",
  "darwin-x64":   "muapi-darwin-x86_64",
  "linux-x64":    "muapi-linux-x86_64",
  "linux-arm64":  "muapi-linux-arm64",
  "win32-x64":    "muapi-windows-x86_64.exe",
};

const key     = `${plat}-${arch}`;
const binName = NAME_MAP[key];
const binPath = binName ? path.join(__dirname, binName) : null;

if (!binPath || !fs.existsSync(binPath)) {
  console.error(`[muapi] No binary found for ${key}.`);
  console.error("[muapi] Try: pip install muapi-cli");
  process.exit(1);
}

const result = spawnSync(binPath, process.argv.slice(2), {
  stdio: "inherit",
  argv0: "muapi",
});
process.exit(result.status ?? 1);
